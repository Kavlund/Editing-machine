# ── Required ──────────────────────────────────────────────────────────────

# Password your team uses to log into the dashboard
DASHBOARD_PASSWORD=set-a-strong-password-here

# Random secret for signing session cookies — generate with:
# python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-random-string

# Your ElevenLabs API key for transcription (get it from elevenlabs.io)
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# ── Optional ──────────────────────────────────────────────────────────────

# Anthropic key for AI editing (hook, filler cuts, keyword captions, B-roll matching)
# ANTHROPIC_API_KEY=your-anthropic-key-here

# Set to 1 when running behind HTTPS (marks session cookie as Secure)
# HTTPS=1

# Port override (Railway sets $PORT automatically)
# PORT=8765

# ── Client integrations (filled in on the setup call) ─────────────────────
# All OFF until set. When present, a finished video is auto-delivered to the
# client's Notion CPS card (matched by name) and their Google Drive.

# Delivery mode: drive_link (default) | notion_upload | both
#   drive_link    -> host on Google Drive, put the link on the Notion card
#   notion_upload -> upload the video straight into Notion (needs a PAID Notion plan)
#   both          -> Drive link AND a native inline copy in Notion
# NOTION_DELIVERY_MODE=notion_upload

# Notion — internal integration token + the CPS database id
# NOTION_API_KEY=secret_xxx
# NOTION_CPS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Property mapping (we read the exact names off their DB on the call):
# NOTION_STATUS_PROPERTY=Status
# NOTION_STATUS_EDITING=Editing
# NOTION_STATUS_READY=Ready
# NOTION_VIDEO_PROPERTY=Video               # URL property (for drive_link mode)
# NOTION_VIDEO_FILES_PROPERTY=Video File    # Files property (for notion_upload mode)

# Google Drive — service account that the client shares their ROOT folder with.
# GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/service-account.json
# ...or paste the JSON inline instead of a file path:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}
#
# Share ONE root folder with the service account. The machine auto-creates
# "<Client Name>/Edited/" under it, so each creator is isolated automatically.
# GDRIVE_ROOT_FOLDER_ID=xxxxxxxxxxxxxxxxxxxxx
# GDRIVE_EDITED_SUBFOLDER=Edited          # name of the per-client output subfolder
# GDRIVE_SHARE_ANYONE=1                    # make the uploaded file link-shareable
#
# (Alternative flat layout — everything into one folder, no per-client split:)
# GDRIVE_FINISHED_FOLDER_ID=xxxxxxxxxxxxxxxxxxxxx

# Slack — get a ping the moment a cut is ready. In Slack: create an app ->
# Incoming Webhooks -> add one to a channel -> paste its URL here. Optional.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# White-label — this one codebase can run multiple branded instances (e.g. the
# client's, and a separate internal one). Set these PER INSTANCE in Railway,
# never in code — a brand's name/logo must never be committed to this shared
# repo, since that would leak one instance's branding into every other one.
# BRAND_NAME=Acquisition Empire
#
# BRAND_LOGO should be a data: URI (paste the whole thing), not a file path —
# that way the logo is a config VALUE on one instance, with nothing to commit.
# Generate one from any PNG: base64 it and prefix with "data:image/png;base64,".
# BRAND_LOGO=data:image/png;base64,iVBORw0KGgoAAAANSUhEUgA...
